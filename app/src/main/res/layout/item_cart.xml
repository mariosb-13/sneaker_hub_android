<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="20dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp"
    app:cardBackgroundColor="@color/color_5">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivCartItemImage"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:scaleType="centerInside"
            android:background="@color/always_white"
            app:shapeAppearanceOverlay="@style/RoundedImageView"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvCartItemDiscountBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_discount_badge"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"
            android:textColor="@color/white"
            android:textSize="10sp"
            android:textStyle="bold"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="@id/ivCartItemImage"
            app:layout_constraintTop_toTopOf="@id/ivCartItemImage"
            tools:text="-20%"
            tools:visibility="visible" />

        <ImageView
            android:id="@+id/ivCartItemDelete"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="6dp"
            android:src="@drawable/ic_close"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/color_7" />

        <TextView
            android:id="@+id/tvCartItemBrand"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"
            android:fontFamily="@font/app_font"
            android:textAllCaps="true"
            android:textColor="@color/color_3"
            android:textSize="10sp"
            app:layout_constraintEnd_toStartOf="@+id/ivCartItemDelete"
            app:layout_constraintStart_toEndOf="@id/ivCartItemImage"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="JORDAN" />

        <TextView
            android:id="@+id/tvCartItemName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:layout_marginEnd="8dp"
            android:fontFamily="@font/app_font"
            android:textColor="@color/color_6"
            android:textSize="15sp"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end"
            app:layout_constraintEnd_toStartOf="@id/ivCartItemDelete"
            app:layout_constraintStart_toStartOf="@id/tvCartItemBrand"
            app:layout_constraintTop_toBottomOf="@id/tvCartItemBrand"
            tools:text="Air Jordan 4 Retro Pale Ivory..." />

        <TextView
            android:id="@+id/tvCartItemSize"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="@font/app_font"
            android:textColor="@color/color_3"
            android:textSize="12sp"
            app:layout_constraintStart_toStartOf="@id/tvCartItemBrand"
            app:layout_constraintTop_toBottomOf="@id/tvCartItemName"
            tools:text="Talla: 38" />

        <TextView
            android:id="@+id/tvCartItemOriginalPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/app_font"
            android:textColor="@color/color_3"
            android:textSize="11sp"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="@id/tvCartItemBrand"
            app:layout_constraintTop_toBottomOf="@id/tvCartItemSize"
            tools:text="210,00 €" />

        <TextView
            android:id="@+id/tvCartItemPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/app_font"
            android:textColor="@color/color_6"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="@id/tvCartItemBrand"
            app:layout_constraintTop_toBottomOf="@id/tvCartItemOriginalPrice"
            app:layout_constraintBottom_toBottomOf="parent"
            tools:text="200,00 €" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintTop_toTopOf="@id/tvCartItemPrice"
            app:layout_constraintBottom_toBottomOf="@id/tvCartItemPrice"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:id="@+id/ivCartItemMinus"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:padding="4dp"
                android:src="@drawable/ic_remove"
                app:tint="@color/color_6" />

            <TextView
                android:id="@+id/tvCartItemQuantity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:text="1"
                android:textColor="@color/color_6"
                android:textSize="16sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/ivCartItemAdd"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:padding="4dp"
                android:src="@drawable/ic_add"
                app:tint="@color/color_6" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>