<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    xmlns:app_res="http://schemas.android.com/apk/res-auto">

    <ImageView
        android:id="@+id/ivSuccess"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/ic_check_circle"
        app_res:layout_constraintBottom_toTopOf="@+id/tvSuccessTitle"
        app_res:layout_constraintEnd_toEndOf="parent"
        app_res:layout_constraintStart_toStartOf="parent"
        app_res:layout_constraintTop_toTopOf="parent"
        app_res:layout_constraintVertical_chainStyle="packed"
        app_res:tint="@color/color_6" />

    <TextView
        android:id="@+id/tvSuccessTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="¡Pago Realizado!"
        android:textColor="@color/color_6"
        android:textSize="28sp"
        android:textStyle="bold"
        app_res:layout_constraintBottom_toTopOf="@+id/tvSuccessMessage"
        app_res:layout_constraintEnd_toEndOf="parent"
        app_res:layout_constraintStart_toStartOf="parent"
        app_res:layout_constraintTop_toBottomOf="@+id/ivSuccess" />

    <TextView
        android:id="@+id/tvSuccessMessage"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="40dp"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:text="Tu pedido ha sido procesado con éxito. Pronto recibirás tus nuevas zapas."
        android:textColor="@color/color_2"
        android:textSize="16sp"
        app_res:layout_constraintBottom_toTopOf="@+id/btnBackToHome"
        app_res:layout_constraintEnd_toEndOf="parent"
        app_res:layout_constraintStart_toStartOf="parent"
        app_res:layout_constraintTop_toBottomOf="@+id/tvSuccessTitle" />

    <Button
        android:id="@+id/btnBackToHome"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginHorizontal="40dp"
        android:layout_marginBottom="50dp"
        android:backgroundTint="@color/color_6"
        android:text="Volver a la tienda"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        app_res:cornerRadius="15dp"
        app_res:layout_constraintBottom_toBottomOf="parent"
        app_res:layout_constraintEnd_toEndOf="parent"
        app_res:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>