<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_side_sheet"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Explorar"
        android:textSize="28sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-black"
        android:textColor="#111111"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Filtra por género y marca"
        android:textSize="14sp"
        android:textColor="#888888"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"/>

    <LinearLayout
        android:id="@+id/genderContainer"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="30dp"
        android:background="@drawable/bg_brand_item"
        android:backgroundTint="#F5F5F5"
        android:orientation="horizontal"
        android:padding="4dp"
        android:weightSum="2"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle">

        <TextView
            android:id="@+id/btnToggleMen"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Hombre"
            android:gravity="center"
            android:textStyle="bold"
            android:textColor="#111111"
            android:background="@drawable/bg_brand_item"
            android:backgroundTint="#FFFFFF"
            android:elevation="2dp"/>

        <TextView
            android:id="@+id/btnToggleWomen"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Mujer"
            android:gravity="center"
            android:textStyle="bold"
            android:textColor="#999999"
            android:background="@null"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvBrands"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Marcas Populares"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#111111"
        android:layout_marginTop="30dp"
        app:layout_constraintTop_toBottomOf="@id/genderContainer"
        app:layout_constraintStart_toStartOf="parent"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/tvBrands"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="20dp">

            <LinearLayout
                android:id="@+id/btnSideNike"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_brand_item"
                android:backgroundTint="#FFFFFF"
                android:elevation="3dp"
                android:paddingHorizontal="20dp"
                android:layout_marginBottom="16dp"
                android:layout_marginHorizontal="2dp"> <ImageView
                android:layout_width="50dp"
                android:layout_height="30dp"
                android:src="@drawable/nike"
                app:tint="#000000"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Nike"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#111111"
                    android:layout_marginStart="20dp"/>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_arrow_right"
                    app:tint="#CCCCCC"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnSideAdidas"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_brand_item"
                android:backgroundTint="#FFFFFF"
                android:elevation="3dp"
                android:paddingHorizontal="20dp"
                android:layout_marginBottom="16dp"
                android:layout_marginHorizontal="2dp">

                <ImageView
                    android:layout_width="50dp"
                    android:layout_height="35dp"
                    android:src="@drawable/adidas"
                    app:tint="#000000"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Adidas"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#111111"
                    android:layout_marginStart="20dp"/>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_arrow_right"
                    app:tint="#CCCCCC"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnSideJordan"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_brand_item"
                android:backgroundTint="#FFFFFF"
                android:elevation="3dp"
                android:paddingHorizontal="20dp"
                android:layout_marginBottom="16dp"
                android:layout_marginHorizontal="2dp">

                <ImageView
                    android:layout_width="50dp"
                    android:layout_height="35dp"
                    android:src="@drawable/jordan"
                    app:tint="#000000"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Jordan"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#111111"
                    android:layout_marginStart="20dp"/>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_arrow_right"
                    app:tint="#CCCCCC"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>