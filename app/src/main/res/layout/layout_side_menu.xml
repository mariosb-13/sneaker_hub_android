<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_side_sheet"
    android:backgroundTint="@color/white"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Explorar"
        android:textSize="28sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-black"
        android:textColor="@color/color_6"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Filtra por género y marca"
        android:textSize="14sp"
        android:textColor="@color/color_2"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"/>

    <LinearLayout
        android:id="@+id/genderContainer"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="30dp"
        android:background="@drawable/bg_brand_item"
        android:backgroundTint="@color/color_5"
        android:orientation="horizontal"
        android:padding="4dp"
        android:weightSum="2"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle">

        <TextView
            android:id="@+id/btnToggleMen"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Hombre"
            android:gravity="center"
            android:textStyle="bold"
            android:textColor="@color/color_6"
            android:background="@drawable/bg_brand_item"
            android:backgroundTint="@color/white"
            android:elevation="2dp"/>

        <TextView
            android:id="@+id/btnToggleWomen"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Mujer"
            android:gravity="center"
            android:textStyle="bold"
            android:textColor="@color/color_2"
            android:background="@null"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvBrands"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Marcas Populares"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/color_6"
        android:layout_marginTop="30dp"
        app:layout_constraintTop_toBottomOf="@id/genderContainer"
        app:layout_constraintStart_toStartOf="parent"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvSideBrands"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:scrollbars="none"
        android:paddingBottom="20dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/tvBrands"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>